#include <iostream>
#include <vector>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(NULL));

    int arr_len;

    cout << "Enter array length: ";
    cin >> arr_len;

    vector<int> arr(arr_len);

    cout << "Generated array: ";

    for (int i = 0; i < arr_len; i++) {
        arr[i] = rand() % 100;
        cout << arr[i] << " ";
    }

    cout << endl;

    int maxIndex = 0;
    int minIndex = 0;

    for (int i = 1; i < arr_len; i++) {
        if (arr[i] > arr[maxIndex]) {
            maxIndex = i;
        }

        if (arr[i] < arr[minIndex]) {
            minIndex = i;
        }
    }

    swap(arr[maxIndex], arr[minIndex]);

    cout << "Modified array: ";

    for (int i = 0; i < arr_len; i++) {
        cout << arr[i] << " ";
    }

    return 0;
}


