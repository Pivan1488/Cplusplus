#include <iostream>
#include <vector>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(NULL));

    int size;
    bool found = false;

    cout << "Enter array length: ";
    cin >> size;

    vector<int> arr(size);

    cout << "Generated array: ";

    for (int i = 0; i < size; i++) {
        arr[i] = rand() % 7 - 3;
        cout << arr[i] << " ";
    }

    cout << endl;

    for (int i = 0; i < size; i++) {
        if (arr[i] == 0) {
            cout << "Index of first zero element: "
                 << i;

            found = true;
            break;
        }
    }

    if (!found) {
        cout << "Array does not contain zero elements.";
    }

    return 0;
}
