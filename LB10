#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(NULL));

    const int m = 4;
    const int n = 3;

    int arr[m][n];

    cout << "Array:\n";

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            arr[i][j] = rand() % 20;
            cout << arr[i][j] << "\t";
        }
        cout << endl;
    }

    cout << endl;

    for (int i = 0; i < m; i++) {
        int evenCount = 0;

        for (int j = 0; j < n; j++) {
            if (arr[i][j] % 2 == 0) {
                evenCount++;
            }
        }

        cout << "Row " << i
             << " even numbers: "
             << evenCount << endl;
    }

    return 0;
}


