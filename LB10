#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(NULL));

    const int m = 3;
    const int n = 4;

    int arr[m][n];

    cout << "Array:\n";

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            arr[i][j] = rand() % 100;
            cout << arr[i][j] << "\t";
        }
        cout << endl;
    }

    int max = arr[0][0];
    int row = 0;
    int col = 0;

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (arr[i][j] > max) {
                max = arr[i][j];
                row = i;
                col = j;
            }
        }
    }

    cout << endl;
    cout << "Maximum element: " << max << endl;
    cout << "Position: [" << row
         << "][" << col << "]";

    return 0;
}

