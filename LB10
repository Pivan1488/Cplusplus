#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    srand(time(NULL));

    const int m = 3;
    const int n = 3;

    int arr[m][n];

    int mainDiagonalSum = 0;
    int secondaryDiagonalSum = 0;

    cout << "Array:\n";

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            arr[i][j] = rand() % 20;

            cout << arr[i][j] << "\t";
        }

        cout << endl;
    }

    for (int i = 0; i < m; i++) {
        mainDiagonalSum += arr[i][i];

        secondaryDiagonalSum += arr[i][n - 1 - i];
    }

    cout << endl;

    cout << "Sum of main diagonal: "
         << mainDiagonalSum << endl;

    cout << "Sum of secondary diagonal: "
         << secondaryDiagonalSum << endl;

    return 0;
}
